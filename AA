-- ════════════════════════════════════════════
--  AUTO CARD PICKER
-- ════════════════════════════════════════════
local cardPickerConnection = nil
local cardPickerScanning   = false
local cardPickerDidFire    = false

local priorityOrder = {
    "Wealth","ExtraLife","AbilityCD","DMG",
    "Walkspeed","GadgetCooldown","UltimateMastery",
}
local cardNameMapping = {
    Wealth="Wealth", ExtraLife="ExtraLife",
    AbilityCD="AbilityCD", AbilityCooldown="AbilityCD",
    DMG="DMG", Damage="DMG", Walkspeed="Walkspeed",
    GadgetCooldown="GadgetCooldown", GadgetCD="GadgetCooldown",
    UltimateMastery="UltimateMastery", UltGain="UltimateMastery",
}

local function getCardPriority(cardName)
    if not cardName then return nil, nil end
    local lower = cardName:lower()
    for i, pName in ipairs(priorityOrder) do
        if lower:find(pName:lower()) then return i, pName end
    end
    for mapKey, mapVal in pairs(cardNameMapping) do
        if lower:find(mapKey:lower()) then
            for i, pName in ipairs(priorityOrder) do
                if mapVal == pName then return i, mapVal end
            end
        end
    end
    return nil, nil
end

local function activateButton(button, withDelay)
    if not button then return end
    task.spawn(function()
        pcall(function() GuiService.SelectedObject = button end)
        if withDelay then task.wait(0.2) end
        pcall(function()
            VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.Return, false, game)
            task.wait(0.05)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
        end)
        task.wait(0.05)
        pcall(function() GuiService.SelectedObject = nil end)
    end)
end

local function scanForCards()
    if cardPickerScanning or cardPickerDidFire then return end
    cardPickerScanning = true
    local container
    pcall(function() container = player.PlayerGui.HUD.Main.Cards.CardsFrame.Container end)
    if not container then cardPickerScanning = false return end
    local cardButtons = {}
    for _, child in ipairs(container:GetChildren()) do
        if child.Name == "CardTemplate" and (child:IsA("TextButton") or child:IsA("ImageButton")) then
            table.insert(cardButtons, child)
        end
    end
    if #cardButtons == 0 then cardPickerScanning = false return end
    local bestPriority, bestButton, bestCardType = 999, nil, nil
    for _, button in ipairs(cardButtons) do
        local cardName
        pcall(function() cardName = button:GetAttribute("CardName") end)
        if not cardName then
            for _, child in ipairs(button:GetChildren()) do
                pcall(function() cardName = child:GetAttribute("CardName") end)
                if cardName then break end
            end
        end
        if not cardName then
            cardName = button.Name
            if button:IsA("TextButton") and button.Text ~= "" then cardName = button.Text end
        end
        if cardName then
            local priority, mappedType = getCardPriority(cardName)
            if priority and priority < bestPriority then
                bestPriority = priority bestButton = button bestCardType = mappedType
            end
        end
    end
    cardPickerScanning = false
    if bestButton and bestCardType and not cardPickerDidFire then
        cardPickerDidFire = true
        Notifier.new({ Title="Card Picker", Content="Selected: "..bestCardType, Duration=3, Icon="rbxassetid://120245531583106" })
        activateButton(bestButton, true)
        task.delay(2.5, function() cardPickerDidFire = false end)
    end
end

local function onCardChildAdded(child)
    task.wait(0.35)
    if not cardPickerEnabled then return end
    if child.Name == "CardTemplate" and (child:IsA("TextButton") or child:IsA("ImageButton")) then
        scanForCards()
    end
end

local function startCardPicker()
    if cardPickerConnection then pcall(function() cardPickerConnection:Disconnect() end) cardPickerConnection = nil end
    cardPickerDidFire = false cardPickerScanning = false
    local container local attempts = 0
    repeat attempts += 1 task.wait(0.5)
        pcall(function() container = player.PlayerGui.HUD.Main.Cards.CardsFrame.Container end)
    until container or attempts >= 15
    if container then
        cardPickerConnection = container.ChildAdded:Connect(onCardChildAdded)
        task.wait(0.5)
        if cardPickerEnabled then scanForCards() end
    end
end

local function stopCardPicker()
    if cardPickerConnection then pcall(function() cardPickerConnection:Disconnect() end) cardPickerConnection = nil end
    cardPickerScanning = false cardPickerDidFire = false
end

-- ════════════════════════════════════════════
--  AUTO RETRY
-- ════════════════════════════════════════════
local autoRetryConnection = nil
local autoRetryLastCheck  = 0
local autoRetryHasFired   = false
local AUTO_RETRY_INTERVAL = 1

local function startAutoRetry()
    if autoRetryConnection then pcall(function() autoRetryConnection:Disconnect() end) autoRetryConnection = nil end
    autoRetryHasFired = false autoRetryLastCheck = tick()
    autoRetryConnection = RunService.Heartbeat:Connect(function()
        if not autoRetryEnabled then return end
        local now = tick()
        if (now - autoRetryLastCheck) < AUTO_RETRY_INTERVAL then return end
        autoRetryLastCheck = now
        local retryButton
        pcall(function() retryButton = player.PlayerGui.HUD.EndScreen.Main.Retry end)
        local isVisible = retryButton and retryButton:IsA("TextButton") and retryButton.Visible
        if isVisible then
            if not autoRetryHasFired then
                autoRetryHasFired = true
