-- ════════════════════════════════════════════
local TARGET_USERID        = 9600914056
local CUSTOM_NAME          = "Lustra"
local nametagCharConn      = nil
local originalNametagText  = nil
local originalNametagColor = nil
local originalTextScaled   = nil
local originalTextSize     = nil

local function applyNametag(character)
    if not character then return end
    local alive = workspace:FindFirstChild("Alive")
    if not alive then return end
    local localModel = alive:FindFirstChild(player.Name)
    if not localModel then return end
    local head = localModel:FindFirstChild("Head")
    if not head then
        local alt = localModel:FindFirstChild("AlternativeAccCuz")
        if alt then head = alt:FindFirstChild("Head") end
    end
    if not head then return end
    local nametag = head:FindFirstChild("Nametag")
    if not nametag then return end
    local lbl = nametag:FindFirstChild("PlayerName")
    if not lbl or not lbl:IsA("TextLabel") then return end
    originalNametagText  = lbl.Text
    originalNametagColor = lbl.TextColor3
    originalTextScaled   = lbl.TextScaled
    originalTextSize     = lbl.TextSize
    lbl.TextScaled = false
    lbl.TextSize   = 25
    lbl.TextColor3 = Color3.fromRGB(255, 0, 255)
    local rank = (player.UserId == TARGET_USERID) and "Owner" or "Member"
    lbl.Text = CUSTOM_NAME .. " | " .. rank
end

local function enableNametag()
    if player.Character then task.wait(0.5) applyNametag(player.Character) end
    nametagCharConn = addConn(player.CharacterAdded:Connect(function(char)
        task.wait(0.5) applyNametag(char)
    end))
end

local function revertNametag()
    if nametagCharConn then pcall(function() nametagCharConn:Disconnect() end) nametagCharConn = nil end
    local alive = workspace:FindFirstChild("Alive")
    if not alive then return end
    local localModel = alive:FindFirstChild(player.Name)
    if not localModel then return end
    local head = localModel:FindFirstChild("Head")
    if not head then
        local alt = localModel:FindFirstChild("AlternativeAccCuz")
        if alt then head = alt:FindFirstChild("Head") end
    end
    if not head then return end
    local nametag = head:FindFirstChild("Nametag")
    if not nametag then return end
    local lbl = nametag:FindFirstChild("PlayerName")
    if lbl and lbl:IsA("TextLabel") then
        lbl.TextScaled = originalTextScaled   ~= nil and originalTextScaled   or false
        lbl.TextSize   = originalTextSize     ~= nil and originalTextSize     or 14
        lbl.TextColor3 = originalNametagColor ~= nil and originalNametagColor or Color3.new(1,1,1)
        lbl.Text       = originalNametagText  ~= nil and originalNametagText  or player.Name
    end
end

