local function tapKey(keyCode)
    VirtualInputManager:SendKeyEvent(true,  keyCode, false, game)
    VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
end

local function fireRage(slotName)
    for _ = 1, 5 do
        Interact:FireServer("Gadget", slotName, "Rage", "Began")
        task.wait(0.002)
    end
end

local function spamSlotTimes(slotName, times)
    for _ = 1, times do
        FuncInteract:InvokeServer("EquipAbility", slotName)
        task.wait(0.05)
    end
end

local function runEndSlots()
    for _, slotName in ipairs(endSlots) do
        if slotName then spamSlotTimes(slotName, 5) end
    end
end

local function spamLoop()
    while spamEnabled do
        for _, slot in ipairs(slots) do
            if not spamEnabled then break end
            if not slot.active then continue end
            FuncInteract:InvokeServer("EquipAbility", slot.name)
            task.wait(0.01)
            task.spawn(function() fireRage(slot.name) end)
            for label, active in pairs(keybindActive) do
                if active and keybindCodes[label] then
                    local kc = keybindCodes[label]
                    task.spawn(function()
                        for _ = 1, 3 do tapKey(kc) task.wait(0.002) end
                    end)
                end
            end
            task.wait(0.01)
        end
    end
end

-- ════════════════════════════════════════════
--  AUTO FARM  (tightened TP)
--
--  Changes from v6:
--    - PlatformStand dropped entirely; it was causing the character to
--      ragdoll mid-teleport and drift off target.
--    - TP wait reduced from 0.08s → 0.05s.
--    - After teleporting, re-reads hrp.Position to confirm arrival
--      and retries up to 3 times before giving up on that target.
--    - Wander now re-samples position fresh each attempt.
--    - Target offset recalculated right before the TP (not before the
--      distance check) so stale pivots don't cause bad destinations.
-- ════════════════════════════════════════════
local autoFarmTeleporting  = false
local autoFarmLastMovePos  = Vector3.new(0,0,0)
local autoFarmLastMoveTime = 0
local autoFarmWandering    = false
local STUCK_THRESHOLD      = 10
local STUCK_TIME           = 5
local WANDER_INTERVAL      = 0.5
local TP_ARRIVE_DIST       = 4    -- studs — how close we need to be after TP
local TP_MAX_RETRIES       = 3    -- how many TP attempts per target per tick

local function getPositionOffset(zombie, mode, studs)
    local root = zombie:FindFirstChild("HumanoidRootPart")
        or zombie:FindFirstChild("Torso")
        or zombie:FindFirstChildWhichIsA("BasePart")
    if not root then return Vector3.new(0, studs, 0) end
    local cf = root.CFrame
    if mode == "Above"  then return cf.UpVector   *  studs end
    if mode == "Below"  then return cf.UpVector   * -studs end
    if mode == "Behind" then return cf.LookVector * -studs end
    if mode == "Front"  then return cf.LookVector *  studs end
    return cf.UpVector * studs
end

local function getWanderTarget()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    local currentY = hrp and hrp.Position.Y or 0
    local parts = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Size.Magnitude > 2
            and math.abs(obj.Position.Y - currentY) <= 20 then
            table.insert(parts, obj)
        end
    end
    if #parts > 0 then
        return parts[math.random(1, #parts)]
    end
    -- fallback: any part, Y clamped
    local all = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Size.Magnitude > 2 then
            table.insert(all, obj)
        end
    end
    if #all == 0 then return nil end
    return all[math.random(1, #all)]
end

-- Teleport hrp to targetPos, wait, return new position.
-- No PlatformStand — avoids ragdoll drift.
local function doTP(targetPos)
    local c    = player.Character
    local root = c and c:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    root.CFrame = CFrame.new(targetPos)
    task.wait(0.05)
    local c2   = player.Character
    local root2 = c2 and c2:FindFirstChild("HumanoidRootPart")
    return root2 and root2.Position or nil
end

local function startAutoFarm()
    if autoFarmConnection then
        pcall(function() autoFarmConnection:Disconnect() end)
        autoFarmConnection = nil
    end
    autoFarmTeleporting  = false
    autoFarmWandering    = false
    autoFarmLastMoveTime = tick()

    autoFarmConnection = RunService.Heartbeat:Connect(function()
        if not autoFarmEnabled then return end
        if autoFarmTeleporting then return end

        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local now    = tick()
        local hrpPos = hrp.Position

        -- movement tracking
        if (hrpPos - autoFarmLastMovePos).Magnitude > STUCK_THRESHOLD then
            autoFarmLastMovePos  = hrpPos
            autoFarmLastMoveTime = now
            autoFarmWandering    = false
        end

        -- scan for alive zombies
        local zombiesFolder  = workspace:FindFirstChild("Zombies")
        local hasAliveZombie = false
        if zombiesFolder then
            for _, z in ipairs(zombiesFolder:GetChildren()) do
                if not z:IsA("Model") then continue end
                local hp
                pcall(function() hp = z.Config.Health.Value end)
                if hp and hp > 0 then
                    local ok, pivot = pcall(function() return z:GetPivot() end)
                    if ok and (hrpPos - pivot.Position).Magnitude <= 500 then
                        hasAliveZombie = true
                        break
                    end
                end
            end
        end

        local isStuck = (not hasAliveZombie) and (now - autoFarmLastMoveTime) >= STUCK_TIME

        -- wander mode
        if isStuck or autoFarmWandering then
            autoFarmWandering = true
            if hasAliveZombie then
                autoFarmWandering    = false
                autoFarmLastMovePos  = hrpPos
                autoFarmLastMoveTime = now
            else
                autoFarmTeleporting = true
                task.spawn(function()
                    task.wait(WANDER_INTERVAL)
                    local part = getWanderTarget()
                    if part then
                        local dest = Vector3.new(
                            part.Position.X,
                            math.clamp(part.Position.Y + 4, hrpPos.Y - 20, hrpPos.Y + 20),
                            part.Position.Z
                        )
                        local arrived = doTP(dest)
                        if arrived then
                            autoFarmLastMovePos  = arrived
                            autoFarmLastMoveTime = tick()
                        end
                    end
                    autoFarmTeleporting = false
                end)
                return
            end
        end

        -- drop dead / gone targets
        if currentTarget then
            local hp
            pcall(function() hp = currentTarget.Config.Health.Value end)
            if not currentTarget.Parent or (hp ~= nil and hp <= 0) then
                currentTarget = nil
            end
        end

        -- find nearest alive zombie
        local bestTarget = currentTarget
        local bestDist   = math.huge

        if currentTarget then
            local ok, pivot = pcall(function() return currentTarget:GetPivot() end)
            if ok then bestDist = (hrpPos - pivot.Position).Magnitude end
        end

        if zombiesFolder then
            for _, z in ipairs(zombiesFolder:GetChildren()) do
                if not z:IsA("Model") then continue end
                if z == currentTarget then continue end
                local hp
                pcall(function() hp = z.Config.Health.Value end)
                if not hp or hp <= 0 then continue end
                local ok, pivot = pcall(function() return z:GetPivot() end)
                if not ok then continue end
                local dist = (hrpPos - pivot.Position).Magnitude
                if dist > 500 then continue end
                if dist < bestDist then
                    bestDist   = dist
                    bestTarget = z
                end
            end
        end

        currentTarget = bestTarget
        if not currentTarget then return end

        -- recalculate offset fresh from live pivot
        local ok, pivot = pcall(function() return currentTarget:GetPivot() end)
        if not ok then currentTarget = nil return end

        local offset    = getPositionOffset(currentTarget, autoPositionMode, autoStuds)
        local targetPos = pivot.Position + offset

        if (hrpPos - targetPos).Magnitude <= TP_ARRIVE_DIST then return end

        -- TP with retry loop
        autoFarmTeleporting = true
        task.spawn(function()
            for attempt = 1, TP_MAX_RETRIES do
                -- recalc target in case zombie moved
                local stillOk, freshPivot = pcall(function() return currentTarget:GetPivot() end)
                if not stillOk or not currentTarget or not currentTarget.Parent then break end

                local freshOffset = getPositionOffset(currentTarget, autoPositionMode, autoStuds)
                local dest        = freshPivot.Position + freshOffset

                local arrived = doTP(dest)
                if arrived and (arrived - dest).Magnitude <= TP_ARRIVE_DIST then
                    autoFarmLastMovePos  = arrived
                    autoFarmLastMoveTime = tick()
                    break
                end

                -- short pause between retries
                if attempt < TP_MAX_RETRIES then task.wait(0.04) end
            end
            autoFarmTeleporting = false
        end)
    end)
end

local function stopAutoFarm()
    if autoFarmConnection then
        pcall(function() autoFarmConnection:Disconnect() end)
        autoFarmConnection = nil
    end
    autoFarmTeleporting = false
    autoFarmWandering   = false
    currentTarget       = nil
end

