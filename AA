-- ════════════════════════════════════════════
--  AUTO ESCAPE
-- ════════════════════════════════════════════
local autoEscapeEnabled    = false
local autoEscapeConnection = nil
local autoEscapeLastCheck  = 0
local autoEscapeFired      = false
local autoEscapeRunning    = false
local AUTO_ESCAPE_INTERVAL = 0.5
local ESCAPE_OBJECTIVE     = "Escape Shibuya!"
local ARRIVE_THRESHOLD     = 8

local function objectiveExists()
    local ok = false
    pcall(function() ok = player.PlayerGui.HUD.Main.Objectives[ESCAPE_OBJECTIVE] ~= nil end)
    return ok
end

local function findEscapeTarget()
    local foundPrompt, foundPart = nil, nil
    pcall(function()
        local entries  = workspace.Map.Objective.Entries
        local portique = entries["double portique"]
        if not portique then return end
        local attachment = portique:FindFirstChild("Attachment")
        if not attachment then return end
        local prompt = attachment:FindFirstChild("ProximityPrompt")
        if not prompt or not prompt:IsA("ProximityPrompt") then return end
        local part = portique:IsA("BasePart") and portique
            or portique:FindFirstChildWhichIsA("BasePart") or portique.PrimaryPart
        if not part then return end
        foundPrompt = prompt foundPart = part
    end)
    if foundPrompt then return foundPrompt, foundPart end
    pcall(function()
        local entries = workspace:FindFirstChild("Map")
            and workspace.Map:FindFirstChild("Objective")
            and workspace.Map.Objective:FindFirstChild("Entries")
        if not entries then return end
        local model = entries:FindFirstChild("Model")
        if not model then return end
        local attachment = model:FindFirstChild("Attachment")
        if not attachment then return end
        local prompt = attachment:FindFirstChild("ProximityPrompt")
        if not prompt or not prompt:IsA("ProximityPrompt") then return end
        local part = model:IsA("BasePart") and model
            or model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart", true)
        if not part then return end
        foundPrompt = prompt foundPart = part
    end)
    return foundPrompt, foundPart
end

local function spamE()
    for _ = 1, 5 do
        VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.E, false, game)
        task.wait(0.03)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        task.wait(0.03)
    end
end

local function firePrompt(prompt)
    local fired = false
    pcall(function() fireproximityprompt(prompt) fired = true end)
    if not fired then spamE() end
end

local function runAutoEscape()
    if autoEscapeFired or autoEscapeRunning then return end
    autoEscapeRunning = true
    local prompt, part = findEscapeTarget()
    if not prompt or not part then autoEscapeRunning = false return end
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then autoEscapeRunning = false return end
    local targetPos = part.Position + Vector3.new(0, 4, 0)
    pcall(function() hrp.CFrame = CFrame.new(targetPos) end)
    task.wait(0.1)
    local arrived = false
    local deadline = tick() + 1.5
    while tick() < deadline do
        task.wait(0.05)
        local c2   = player.Character
        local hrp2 = c2 and c2:FindFirstChild("HumanoidRootPart")
        if hrp2 and (hrp2.Position - part.Position).Magnitude <= ARRIVE_THRESHOLD then
            arrived = true break
        end
    end
    if not arrived then
        local c3   = player.Character
        local hrp3 = c3 and c3:FindFirstChild("HumanoidRootPart")
        if hrp3 then
            pcall(function() hrp3.CFrame = CFrame.new(targetPos) end)
            task.wait(0.12)
            local c4   = player.Character
            local hrp4 = c4 and c4:FindFirstChild("HumanoidRootPart")
            if hrp4 and (hrp4.Position - part.Position).Magnitude <= ARRIVE_THRESHOLD then
                arrived = true
            end
        end
    end
    if not arrived then autoEscapeRunning = false return end
    autoEscapeFired = true
    Notifier.new({ Title="Auto Escape", Content="Firing escape prompt!", Duration=3, Icon="rbxassetid://120245531583106" })
    firePrompt(prompt)
    task.delay(5, function() autoEscapeFired = false autoEscapeRunning = false end)
end

local function startAutoEscape()
    if autoEscapeConnection then pcall(function() autoEscapeConnection:Disconnect() end) autoEscapeConnection = nil end
    autoEscapeFired = false autoEscapeRunning = false autoEscapeLastCheck = tick()
    autoEscapeConnection = RunService.Heartbeat:Connect(function()
        if not autoEscapeEnabled then return end
        local now = tick()
        if (now - autoEscapeLastCheck) < AUTO_ESCAPE_INTERVAL then return end
        autoEscapeLastCheck = now
        if objectiveExists() then
            task.spawn(runAutoEscape)
        else
            if autoEscapeFired or autoEscapeRunning then
                autoEscapeFired = false autoEscapeRunning = false
            end
        end
    end)
end

local function stopAutoEscape()
    if autoEscapeConnection then pcall(function() autoEscapeConnection:Disconnect() end) autoEscapeConnection = nil end
    autoEscapeFired = false autoEscapeRunning = false
end

