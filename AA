--  STARTUP WALK  (0.7 seconds, then hard stop)
-- ════════════════════════════════════════════
local function doStartupWalk()
    local char = player.Character or player.CharacterAdded:Wait()
    local hum  = char:FindFirstChildOfClass("Humanoid")
        or char:WaitForChild("Humanoid", 10)
    if not hum then return end

    local angle = math.random() * math.pi * 2
    local dir   = Vector3.new(math.cos(angle), 0, math.sin(angle))

    local WALK_DURATION = 0.7
    local startTime     = tick()
    local conn

    conn = RunService.RenderStepped:Connect(function()
        if tick() - startTime >= WALK_DURATION then
            conn:Disconnect()
            local c = player.Character
            local h = c and c:FindFirstChildOfClass("Humanoid")
            if h then h:Move(Vector3.zero, false) end
            return
        end
        local c = player.Character
        local h = c and c:FindFirstChildOfClass("Humanoid")
        if h then h:Move(dir, false) end
    end)

    task.wait(WALK_DURATION + 0.05)
end

doStartupWalk()

