--  SLOT DISCOVERY
-- ════════════════════════════════════════════
local function discoverSlotNames()
    local found = {}
    for _, child in ipairs(player:GetChildren()) do
        local n = child.Name:match("^Slot(%d+)Ult$")
        if n then table.insert(found, { name="Slot"..n, index=tonumber(n) }) end
    end
    table.sort(found, function(a, b) return a.index < b.index end)
    local names = {}
    for _, v in ipairs(found) do table.insert(names, v.name) end
    return names
end

