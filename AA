local function buildSlotToggles(slotNames)
    local prevActive = {}
    for _, slot in ipairs(slots) do prevActive[slot.name] = slot.active end
    for _, ref in pairs(slotToggleRefs) do pcall(function() ref:Destroy() end) end
    table.clear(slotToggleRefs) table.clear(slots)
    if #slotNames == 0 then
        SpamRight:AddParagraph({ Title="No Slots Found", Content="No SlotNUlt values on LocalPlayer.\nValues will appear when detected." })
        return
    end
    for _, name in ipairs(slotNames) do
        local wasActive = prevActive[name] ~= false
        local slotRef   = { name=name, active=wasActive }
        table.insert(slots, slotRef)
        local tog = SpamRight:AddToggle({ Name=name, Default=wasActive, Callback=function(v) slotRef.active=v end })
        slotToggleRefs[name] = tog
    end
end

