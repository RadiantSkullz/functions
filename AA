-- ════════════════════════════════════════════
--  AUTO EXECUTE
--
--  Key fix: resolve queue_on_teleport LAZILY at arm-time, not at load-time.
--  Some executors (including those running IY) expose the global only after
--  the initial environment is fully set up. Trying to read it at the top of
--  the script gets nil even though it'll be there a moment later.
--
--  tryQueue() tries every known alias in order, pcall-guarded, each time
--  armAutoExecute() is called. First one that works wins.
-- ════════════════════════════════════════════
local SCRIPT_FILE = "SlotSpam/SlotSpam_script.lua"
local AE_FLAG     = "SlotSpam/AutoExecute.txt"
local AC_FILE     = "SlotSpam/AutoLoadConfig.txt"

local LOADER_STUB = [[
pcall(function()
    if isfile and isfile("SlotSpam/SlotSpam_script.lua") then
        loadstring(readfile("SlotSpam/SlotSpam_script.lua"))()
    end
end)
]]

local function tryQueue(code)
    -- Try every known alias. Stop at first success.
    if pcall(function() queue_on_teleport(code) end)             then return true end
    if syn and pcall(function() syn.queue_on_teleport(code) end) then return true end
    if fluxus and pcall(function() fluxus.queue_on_teleport(code) end) then return true end
    if pcall(function() queueonteleport(code) end)               then return true end
    return false
end

local function getSelfSource()
    local src
    pcall(function() src = getscriptcontent() end)
    if src and #src > 200 then return src end
    pcall(function() src = getscriptsource() end)
    if src and #src > 200 then return src end
    pcall(function()
        local s = getfenv(0).script or getfenv(1).script
        if s and typeof(s) == "Instance" then src = s.Source end
    end)
    if src and #src > 200 then return src end
    if _isfile(SCRIPT_FILE) then
        src = _readfile(SCRIPT_FILE)
        if src and #src > 200 then return src end
    end
    return nil
end

local function saveScriptToDisk()
    ensureDir("SlotSpam")
    local src = getSelfSource()
    if not src or #src <= 200 then return false end
    _writefile(SCRIPT_FILE, src)
    return true
end

local function writeFlag(val)
    ensureDir("SlotSpam")
    _writefile(AE_FLAG, val and "true" or "false")
end

local function readFlag()
    if not _isfile(AE_FLAG) then return false end
    local content = _readfile(AE_FLAG)
    return type(content) == "string" and content:lower():find("true") ~= nil
end

local function writeConfigName(name)
    ensureDir("SlotSpam")
    _writefile(AC_FILE, name or "None")
end

local function readConfigName()
    if not _isfile(AC_FILE) then return "None" end
    local content = _readfile(AC_FILE)
    if type(content) == "string" then
        local trimmed = content:match("^%s*(.-)%s*$")
        if trimmed and trimmed ~= "" then return trimmed end
    end
    return "None"
end

local function armAutoExecute()
    if not autoExecuteEnabled then return end
    saveScriptToDisk()
    writeConfigName(autoLoadConfig)
    tryQueue(LOADER_STUB)
end

-- Load persisted state
autoExecuteEnabled = readFlag()
